#!/usr/bin/env bash
# post-commit: [태그] 커밋 시 CHANGELOG + SESSION 자동 갱신. 차단 없음.

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

MSG="$(git log -1 --pretty=%s)"
HASH="$(git log -1 --pretty=%h)"
DATE="$(date +%Y-%m-%d)"

# 태그 추출: [Feat], [Fix], [Refactor], [Style], [Docs], [Test], [Chore], [CI]
if [[ "$MSG" =~ ^\[(Feat|Fix|Refactor|Style|Docs|Test|Chore|CI)\] ]]; then
  TAG="${BASH_REMATCH[1]}"

  # CHANGELOG 프리펜드 — 가장 단순한 구조: 시간순 역순 flat list
  CHANGELOG="$REPO_ROOT/CHANGELOG.md"
  if [[ ! -f "$CHANGELOG" ]]; then
    {
      echo "# Changelog"
      echo ""
      echo "이 프로젝트의 변경 이력. \`[태그]\` 커밋에 대해 \`post-commit\` 훅이 자동 기록."
      echo ""
    } > "$CHANGELOG"
  fi

  # 제목 추출: "[Tag] - body" 또는 "[Tag] body" 양쪽 지원
  BODY="$(echo "$MSG" | sed -E "s/^\[$TAG\][[:space:]]*-?[[:space:]]*//")"
  ENTRY="- \`$DATE\` **[$TAG]** $BODY (\`$HASH\`)"

  # 첫 4줄(헤더+설명) 뒤에 entry 삽입
  TMP="$(mktemp)"
  {
    head -4 "$CHANGELOG"
    echo "$ENTRY"
    tail -n +5 "$CHANGELOG"
  } > "$TMP"
  mv "$TMP" "$CHANGELOG"

  # SESSION.md는 자동생성하지 않음 — /session-end 스킬로 수동 관리
  # (이전 버전은 매 커밋마다 SESSION.md를 덮어써서 세션 핸드오프 메모가 소실됨)

  echo "[post-commit] CHANGELOG 갱신 완료 ([$TAG])"
fi

exit 0
