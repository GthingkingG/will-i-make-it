{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(flutter:*)",
      "Bash(dart:*)",
      "Bash(fvm:*)",
      "Bash(pod:*)",
      "Bash(xcrun:*)",
      "Bash(simctl:*)",
      "Bash(open:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(rm:*)",
      "Bash(touch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(test:*)",
      "Bash(true)",
      "Bash(false)",
      "Bash(actionlint:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(bash:*)",
      "Bash(chmod:*)",
      "Bash(diff:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tee:*)",
      "Edit",
      "Write",
      "MultiEdit",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm:-rf /*)",
      "Bash(rm:-rf ~)",
      "Bash(rm:-rf ~/*)",
      "Bash(git push:--force *)",
      "Bash(git push:-f *)",
      "Bash(git reset:--hard *)",
      "Bash(git commit:--amend *)",
      "Bash(git commit:*--no-verify*)",
      "Bash(git push:*--no-verify*)",
      "Bash(gh pr merge:*)",
      "Bash(gh repo delete:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop"
          }
        ]
      }
    ]
  }
}
